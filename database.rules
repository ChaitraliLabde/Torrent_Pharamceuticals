{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "sales_entries": {
      ".read": "auth != null",
      "$entryId": {
        ".write": "auth != null && ( (!data.exists() && newData.child('enteredBy').val() == auth.uid) || (data.exists() && (data.child('enteredBy').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')) )"
      }
    },
    "doctor_visits": {
      ".read": "auth != null",
      "$visitId": {
        ".write": "auth != null && ( (!data.exists() && newData.child('enteredBy').val() == auth.uid) || (data.exists() && (data.child('enteredBy').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')) )"
      }
    },
    "targets": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
    },
    "manufacturing_planning": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'manager')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'manager')"
    },
